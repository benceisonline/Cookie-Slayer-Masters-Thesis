{
  "manifest_version": 3,
  "name": "Cookie Slayer",
  "version": "1.0",
  "description": "Your best friend in privacy.",
  "permissions": ["scripting", "activeTab"],
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": ["scripts/*.js", "styles.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/loader.js"] 
    }
  ]
}
